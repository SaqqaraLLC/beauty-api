            "type": "string",
            "nullable": true
          },
          "locationId": {
            "type": "integer",
            "format": "int64"
          },
          "locationName": {
            "type": "string",
            "nullable": true
          },
          "startsAtUtc": {
            "type": "string",
            "format": "date-time"
